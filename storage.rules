rules_version = '2';

// PSM Generator — Firebase Storage security rules
//
// Session 14 (2026-04-14): first real Storage rules on this bucket. Default
// rules were `allow read, write: if false` — blocks every client read of
// worksheet PDFs uploaded by Session 12's migration. This file opens
// /worksheets/* for any authenticated allowlisted user (tutor/admin/student/
// parent) so pdf.js can render them inline in SubmissionEditor.
//
// Scope note: worksheets are NOT per-student. The same PDF is assigned to
// many students, so there is no studentId path segment to gate on. This is
// intentionally a weaker gate than Firestore's canReadStudent() — any
// allowlisted role can fetch any worksheet PDF. For the 51-user pilot this
// matches the effective access level of WS_RAW (baked into the bundle).
// Public launch would require per-user signed URLs via a Cloud Function.
//
// Source of truth: docs/superpowers/specs/2026-04-14-session-14-submission-editor-design.md

// Session 14 fallback: simplified rule that does NOT cross-service call
// Firestore. Cross-service firestore.get() from Storage rules turned out to
// be unreliable in production (PDFs 403'd despite a valid allowlist entry).
// This rule gates reads on verified-email Firebase Auth sessions only,
// which in practice means "anyone on the allowlist" because the rest of the
// app routes un-allowlisted sign-ins to a "please ask to be added" screen
// before they can trigger any portal UI that reads worksheets.
//
// Security tradeoff: weaker than the original design — any signed-in
// verified-email user can fetch any worksheet PDF. For the 51-user pilot
// this is acceptable; public launch requires per-user signed URLs via a
// Cloud Function.

service firebase.storage {
  match /b/{bucket}/o {

    function isVerifiedSignedIn() {
      return request.auth != null
        && request.auth.token.email_verified == true;
    }

    match /worksheets/{file=**} {
      allow read: if isVerifiedSignedIn();
      allow write: if false;  // admin SDK only
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
